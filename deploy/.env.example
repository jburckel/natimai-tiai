# Copie en .env et renseigne les valeurs. Ne JAMAIS committer .env.

# --- Nom du serveur (doit correspondre au CN/SAN du certificat AC interne) ---
TIAI_SERVER_NAME=tiai.natimai.local

# --- PostgreSQL ---
POSTGRES_USER=tiai
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=tiai

# --- Backend ---
ENVIRONMENT=production
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
# Premier compte admin, créé au démarrage s'il n'existe pas encore.
FIRST_ADMIN_EMAIL=admin@natimai.solutions
FIRST_ADMIN_PASSWORD=changeme-strong-admin-password
# Secret d'enrôlement partagé (déployé par GPO côté agents). Ne sert qu'à /enroll.
ENROLLMENT_SECRET=changeme-shared-enrollment-secret
# Origines CORS autorisées pour la console (séparées par des virgules).
BACKEND_CORS_ORIGINS=https://tiai.natimai.local

# --- Alertes e-mail (Mailgun) ---
MAILGUN_API_BASE_URL=https://api.mailgun.net/v3
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_FROM_EMAIL=tiai@natimai.solutions
MAILGUN_FROM_NAME=Tiai
ALERT_RECIPIENTS=
