# Caddy — reverse-proxy + terminaison TLS pour Tiai.
#
# Le certificat serveur est émis par l'AC interne (AD CS) pour le nom du
# serveur. Les postes du domaine font déjà confiance à cette AC racine.
# Place le certificat et sa clé dans deploy/certs/ (montés en lecture seule).
#
# Sans certificat fourni (dev / tests), remplace la ligne `tls` par :
#     tls internal
# → Caddy génère un certificat local auto-signé, aucune dépendance à un certif.
# (Pour des tests en HTTP pur, on peut aussi viser directement le backend:8000
#  sans passer par Caddy — cf. §2.12 : le TLS n'est pas une dépendance dure.)

{$TIAI_SERVER_NAME:tiai.natimai.local} {
	tls /etc/caddy/certs/tiai.crt /etc/caddy/certs/tiai.key

	# En-têtes de sécurité — posés ici (seul point d'exposition) plutôt que
	# dans nginx : `header` écrase toute valeur amont, source de vérité unique.
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# CSP pour la SPA Quasar : scripts/styles servis par le build (self) ;
		# 'unsafe-inline' requis pour les styles inline posés par Quasar/Vue.
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# API backend
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	# Console (build Quasar servi par nginx)
	handle {
		reverse_proxy frontend:80
	}

	encode gzip
}
