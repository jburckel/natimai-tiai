# Caddy — variante DEV : TLS auto-signé (`tls internal`), aucun certificat à
# fournir. Monté à la place du Caddyfile par docker-compose.dev.yml.
#
# Pour que l'agent Windows (vérification TLS non désactivable) accepte ce
# certificat, importer la racine locale de Caddy dans le magasin machine :
#   docker compose cp caddy:/data/caddy/pki/authorities/local/root.crt .
#   certutil -addstore Root root.crt
#
# Différences avec le Caddyfile de prod :
#   - `tls internal` au lieu du certificat AC interne ;
#   - pas de HSTS : éviter d'épingler « HTTPS obligatoire » dans le navigateur
#     pour ce nom d'hôte pendant les tests (cache HSTS d'un an).

{$TIAI_SERVER_NAME:tiai.natimai.local} {
	tls internal

	# Mêmes en-têtes qu'en prod (hors HSTS) pour valider la CSP en dev.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# API backend
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	# Console (build Quasar servi par nginx)
	handle {
		reverse_proxy frontend:80
	}

	encode gzip
}
