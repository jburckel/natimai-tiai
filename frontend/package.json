{
  "name": "tiai-frontend",
  "version": "0.1.0",
  "description": "Tiai — console web de supervision",
  "productName": "Tiai",
  "author": "Natimai",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build -m spa",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,js,vue,json,scss,css,html,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,vue,json,scss,css,html,md}\"",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.0",
    "axios": "^1.7.0",
    "pinia": "^3.0.0",
    "quasar": "^2.16.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.0.0",
    "@types/node": "^22.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": "^22 || ^20"
  }
}
